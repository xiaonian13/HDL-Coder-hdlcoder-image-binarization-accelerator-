#include <stdio.h>
#include "xil_printf.h"
#include "xil_io.h"
#include "xil_types.h"
#include "sleep.h"

// ==============================================================================
// 1. 基地址定义（⚠️已修正：去掉了 C 语言不支持的下划线）
// ==============================================================================
#define XPAR_IMG_THRESHOLD_BASEADDR    0x80000000U

#define REG_IPCORE_RESET       (XPAR_IMG_THRESHOLD_BASEADDR + 0x00U)  // 只写
#define REG_IPCORE_ENABLE      (XPAR_IMG_THRESHOLD_BASEADDR + 0x04U)  // 读写
#define REG_IPCORE_TIMESTAMP   (XPAR_IMG_THRESHOLD_BASEADDR + 0x08U)  // 只读
#define REG_PIXEL_IN_DATA      (XPAR_IMG_THRESHOLD_BASEADDR + 0x100U) // 只写
#define REG_VALID_IN_DATA      (XPAR_IMG_THRESHOLD_BASEADDR + 0x104U) // 只写
#define REG_THRESHOLD_DATA     (XPAR_IMG_THRESHOLD_BASEADDR + 0x108U) // 只写
#define REG_PIXEL_OUT_DATA     (XPAR_IMG_THRESHOLD_BASEADDR + 0x10CU) // 只读
#define REG_VALID_OUT_DATA     (XPAR_IMG_THRESHOLD_BASEADDR + 0x110U) // 只读

int main()
{
    // ⚠️已修正：删除了导致报错的 init_platform()
    xil_printf("\n\r[VITIS_TEST] ================================================");
    xil_printf("\n\r[VITIS_TEST] ------ ZynqMP XCZU15EG 算法参数测试启动 ------");
    xil_printf("\n\r[VITIS_TEST] ================================================");

    // ==============================================================================
    // 2. 步骤一：强行解除内部软件锁死
    // ==============================================================================
    xil_printf("\n\r[VITIS_TEST] 正在向 0x00 写入 0，解除内部软件复位状态...");
    Xil_Out32(REG_IPCORE_RESET, 0x00000000U);
    usleep(10);

    // ==============================================================================
    // 3. 步骤二：读取并校验硬件时间戳
    // ==============================================================================
    xil_printf("\n\r[VITIS_TEST] 正在读取寄存器 0x08 以校验 IP 核时间戳...");
    u32 timestamp = Xil_In32(REG_IPCORE_TIMESTAMP);
    xil_printf("\n\r[VITIS_TEST] 读取到的硬件时间戳为: %u", timestamp);

    if (timestamp == 2105211101U) {
        xil_printf("\n\r[VITIS_TEST] >>> [SUCCESS] 时间戳硬件校对完全正确！");
    } else {
        xil_printf("\n\r[VITIS_TEST] >>> [WARNING] 时间戳不匹配！");
    }

    // ==============================================================================
    // 4. 步骤三：使能开启 IP 核核心算法
    // ==============================================================================
    xil_printf("\n\r[VITIS_TEST] 正在向 0x04 写入 1，正式使能 IP 核心流水线...");
    Xil_Out32(REG_IPCORE_ENABLE, 0x00000001U);
    usleep(10);

    // ==============================================================================
    // 5. 步骤四：写入参数（二值化阈值）
    // ==============================================================================
    u32 target_threshold = 128;
    xil_printf("\n\r[VITIS_TEST] [WRITE] 正在配置二值化阈值 (0x108) = %u", target_threshold);
    Xil_Out32(REG_THRESHOLD_DATA, target_threshold);

    // ==============================================================================
    // 6. 步骤五：馈送模拟数据
    // ==============================================================================
    u32 test_pixel = 150;
    xil_printf("\n\r[VITIS_TEST] [WRITE] 正在向输入寄存器 (0x100) 馈送模拟像素: %u", test_pixel);
    Xil_Out32(REG_PIXEL_IN_DATA, test_pixel);
    Xil_Out32(REG_VALID_IN_DATA, 0x00000001U);

    usleep(20); // 等待核心算法流水线处理完成

    // ==============================================================================
    // 7. 步骤六：获取计算数据
    // ==============================================================================
    u32 val_out = Xil_In32(REG_VALID_OUT_DATA);
    u32 pix_out = Xil_In32(REG_PIXEL_OUT_DATA);

    xil_printf("\n\r[VITIS_TEST] ================================================");
    xil_printf("\n\r[VITIS_TEST] 硬件执行报告：");
    xil_printf("\n\r[VITIS_TEST] 输出有效状态 (Valid Out): %u", val_out);
    xil_printf("\n\r[VITIS_TEST] 输出像素结果 (Pixel Out): 0x%08X", pix_out);

    if (pix_out == 0x000000FFU) {
        xil_printf("\n\r[VITIS_TEST] >>> [SUCCESS] 最终测试通过！输出纯白像素(255)！");
    } else {
        xil_printf("\n\r[VITIS_TEST] >>> [FAIL] 计算错误或未捕捉到数据。");
    }
    xil_printf("\n\r[VITIS_TEST] ================================================");

    // ⚠️已修正：删除了导致报错的 cleanup_platform()
    return 0;
}
